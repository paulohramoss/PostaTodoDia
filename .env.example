# Banco de dados PostgreSQL (Neon, Supabase, Vercel Postgres, etc.)
# Exemplo Neon: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Chave da API Gemini — obtenha em https://aistudio.google.com/app/apikey
# Sem essa chave, a geração de conteúdo e imagem usa fallback local
GEMINI_API_KEY=

# Opcional: modelo usado para a imagem generativa do preview de Instagram
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
